{
	"name": "@kumofire/jobs",
	"version": "0.1.4",
	"description": "A job processing library for Cloudflare Workers.",
	"type": "module",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"bin": {
		"kumofire-jobs": "./dist/cli.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./sql/*": "./sql/*"
	},
	"files": [
		"dist",
		"sql"
	],
	"scripts": {
		"sync:schema": "node scripts/sync-sqlite-schema.mjs",
		"build": "pnpm run sync:schema && tsdown src/index.ts src/cli.ts --format esm --dts",
		"test": "vitest run",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "pnpm run sync:schema && tsc --noEmit"
	},
	"keywords": [
		"cloudflare",
		"workers",
		"jobs",
		"queue"
	],
	"author": "tsugumi-sys <tidemark0105@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsugumi-sys/kumofire-jobs.git",
		"directory": "typescript"
	},
	"homepage": "https://github.com/tsugumi-sys/kumofire-jobs/tree/main/typescript",
	"bugs": {
		"url": "https://github.com/tsugumi-sys/kumofire-jobs/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"@cloudflare/workers-types": "^4.20260317.1"
	},
	"devDependencies": {
		"@types/node": "^24.7.2",
		"@biomejs/biome": "^2.4.8",
		"tsdown": "^0.21.4",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	}
}
